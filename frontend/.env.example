# Variables d'environnement frontend — Vercel
# Copier ce fichier en .env.local pour le développement local

# URL complète du backend Render (SANS slash final)
# En développement : laisser vide (le proxy Vite gère /api)
VITE_API_URL=

# En production sur Vercel, configurer cette variable dans :
# Vercel Dashboard → Project → Settings → Environment Variables
# VITE_API_URL=https://xeetali-backend.onrender.com
