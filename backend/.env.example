# Variables d'environnement backend — Render
# Copier ce fichier en .env pour le développement local
# NE PAS committer le fichier .env avec de vraies valeurs !

# URL PostgreSQL (fournie automatiquement par Render en production)
DATABASE_URL=postgresql://xeetali:xeetali_password@db:5432/xeetali_db

# Secret JWT — générer une valeur sécurisée : openssl rand -hex 32
JWT_SECRET=dev-secret-change-me-in-production

# Origines CORS autorisées (séparées par des virgules)
# En développement :
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# En production (remplacer par votre URL Vercel) :
# CORS_ORIGINS=https://xeetali.vercel.app
